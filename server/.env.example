PORT=3000
NODE_ENV=development

DATABASE_URL=postgres://postgres:admin@localhost:5432/cinezone

JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:4200

# VidAPI/Vaplayer
VIDAPI_BASE_URL=https://vidapi.ru
VIDAPI_PLAYER_BASE_URL=https://vaplayer.ru

# TMDB (The Movie Database) — free API key at https://www.themoviedb.org/settings/api
# Powers movie search when IMDB is not configured.
TMDB_API_KEY=

# Optional official IMDb API through AWS Data Exchange.
# When these are missing, the server uses VidAPI listing metadata as a fallback catalog.
IMDB_API_KEY=
IMDB_DATA_SET_ID=
IMDB_REVISION_ID=
IMDB_ASSET_ID=
AWS_REGION=us-east-1
